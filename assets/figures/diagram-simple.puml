@startuml
left to right direction
' top to bottom direction

' === Global look & feel =============
skinparam defaultFontSize 20
' skinparam BackgroundColor #00000010
skinparam BackgroundColor transparent

' ======================================
skinparam package {
    RoundCorner 15
    BorderThickness 2
    ' BackgroundColor #00A2FF19
    ' BorderColor #00A2FF
    ' FontColor   #00A2FF
}
skinparam package<<Global Environment>><<Python Package>> {
    BackgroundColor #afb20019
    BorderColor #afb200ff
    FontColor   #afb200ff
}
skinparam package<<Virtual Environment>>{
    BackgroundColor #32bc0019
    BorderColor #32bc00ff
    FontColor   #32bc00ff
}
skinparam package<<Directory>> {
    BackgroundColor #00A2FF19
    BorderColor #00A2FF
    FontColor   #00A2FF
}

' ======================================
skinparam class {
    BackgroundColor #cccccc77
    BorderColor     #444444
    BorderThickness 1
    FontStyle bold
    RoundCorner 15
}
skinparam class<<CLI>> {
    BorderColor     #000000
}
skinparam class<<Config>><<Pkg>><<Lock-Files>><<File>><<Lock-File>> {
    BorderColor     #000000
    BorderThickness 0
}


' =================================================

' === Packages (now ordered GE → PDIR → VENV) ===
package "Operating System" as GE <<Global Environment>> {
    interface "uv" as UVG  <<CLI>> {
        +python install()
        +venv()
        +lock()
        +sync()
        +run()
    }
}

package "Project Directory" as PDIR <<Directory>> {
    class "pyproject.toml"   as PPRT <<Config>>{
        +Dependencies
        +Project Metadata
    }
    class "uv.lock"         as LOCK <<Lock-File>>{
        +Dependencies
        +Versions
        +Sources
    }
    class "main.py\n(or other code)" as APP <<File>>
}



package ".venv" as VENV <<Virtual Environment>> {
    class "Python Dependencies" as PKG <<Pkg>>
}

' === Hidden arrows to lock horizontal order ===
GE   -right[hidden]-> PDIR
PDIR -right[hidden]-> VENV

' === Visible blue arrows (same semantics) ===
<style>
arrow {
    LineColor #00A2FF
    LineThickness 2.5
    FontColor #00A2FF
    FontStyle italic
}
</style>


PPRT <-- USER : edits
LOCK <-- UVG  : resolves

LOCK <-- USER : reviews

' === SPecial Straight Arrows =============
<style>
arrow {
    LineColor #32bc00ff
    FontColor #32bc00ff
}
</style>



abstract "User" as USER <<Actor>> {
    +eat()
    +sleep()
    +code()
}

UVG --> PKG  : syncs
UVG  -[thickness=4]-> VENV : **creates**
USER  --> VENV : runs uv, \n activates \n& manages 

<style>
arrow {
    LineStyle 10-5
    LineColor #EE220C
    FontColor #EE220C
}
</style>
APP --> PKG  : requires
PPRT <-- UVG  : reads\ndependency specs
LOCK <-- UVG  : reads

@enduml
